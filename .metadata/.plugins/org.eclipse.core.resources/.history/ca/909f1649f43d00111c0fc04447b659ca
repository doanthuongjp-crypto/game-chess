package com.chess.view;

import java.awt.Color;
import java.awt.Dimension;
import java.awt.Graphics;
import java.awt.Graphics2D;
import java.awt.Point;
import java.util.ArrayList;
import java.util.List;

import javax.swing.JPanel;

import com.chess.model.Piece;

public class GamePanel extends JPanel {
    private final int TILE_SIZE = 80;
    private Piece[][] board;
    
    // Các biến phục vụ hiệu ứng
    public Point selectedSquare = null; // Ô đang được click chọn
    public List<Point> validMoves = new ArrayList<>(); // Danh sách các ô có thể đi

    public GamePanel(Piece[][] board) {
        this.board = board;
        this.setPreferredSize(new Dimension(8 * TILE_SIZE, 8 * TILE_SIZE));
    }

    @Override
    protected void paintComponent(Graphics g) {
        super.paintComponent(g);
        drawBoard(g);
        drawEffects(g); // Vẽ hiệu ứng đè lên bàn cờ
        drawPieces(g);
    }

    private void drawBoard(Graphics g) {
        for (int row = 0; row < 8; row++) {
            for (int col = 0; col < 8; col++) {
                if ((row + col) % 2 == 0) g.setColor(new Color(235, 235, 208));
                else g.setColor(new Color(119, 148, 85));
                g.fillRect(col * TILE_SIZE, row * TILE_SIZE, TILE_SIZE, TILE_SIZE);
            }
        }
    }

    private void drawEffects(Graphics g) {
        Graphics2D g2 = (Graphics2D) g;

        // 1. Highlight ô đang chọn (Màu vàng nhạt)
        if (selectedSquare != null) {
            g2.setColor(new Color(255, 255, 0, 100)); // Màu vàng trong suốt
            g2.fillRect(selectedSquare.x * TILE_SIZE, selectedSquare.y * TILE_SIZE, TILE_SIZE, TILE_SIZE);
        }

        // 2. Highlight các ô có thể di chuyển (Dấu chấm tròn hoặc viền)
        g2.setColor(new Color(0, 0, 0, 50)); // Màu đen mờ
        for (Point p : validMoves) {
            // Vẽ một hình tròn nhỏ ở giữa ô
            g2.fillOval(p.x * TILE_SIZE + 30, p.y * TILE_SIZE + 30, 20, 20);
        }
    }

    private void drawPieces(Graphics g) {
        for (int row = 0; row < 8; row++) {
            for (int col = 0; col < 8; col++) {
                Piece p = board[row][col];
                if (p != null && p.img != null) {
                    g.drawImage(p.img, col * TILE_SIZE, row * TILE_SIZE, TILE_SIZE, TILE_SIZE, null);
                }
            }
        }
    }
}