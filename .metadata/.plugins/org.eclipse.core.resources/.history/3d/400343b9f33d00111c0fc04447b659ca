package com.chess.model;

public class Pawn extends Piece {
    public Pawn(int row, int col, boolean isWhite) {
        super(row, col, isWhite, "pawn");
    }

    @Override
    public boolean isValidMove(int targetRow, int targetCol, Piece[][] board) {
        int direction = isWhite ? -1 : 1;
        Piece target = board[targetRow][targetCol];

        // 1. Đi thẳng 1 ô
        if (targetCol == this.col && targetRow == this.row + direction && target == null) {
            return true;
        }
        // 2. Đi thẳng 2 ô lúc xuất phát
        if (targetCol == this.col && target == null) {
            if (isWhite && this.row == 6 && targetRow == 4 && board[5][this.col] == null) return true;
            if (!isWhite && this.row == 1 && targetRow == 3 && board[2][this.col] == null) return true;
        }
        // 3. Ăn chéo
        if (Math.abs(targetCol - this.col) == 1 && targetRow == this.row + direction) {
            return target != null && target.isWhite != this.isWhite;
        }

        return false;
    }
}